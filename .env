# ==============================
# Application Configuration
# ==============================

BASE_URL=http://automationexercise.com
ENV=QA

# ==============================
# Browser Configuration
# ==============================

BROWSER=chromium
HEADLESS=false
SLOW_MO=0

# ==============================
# Timeout Configuration
# ==============================

DEFAULT_TIMEOUT=60000
NAVIGATION_TIMEOUT=60000

# ==============================
# Reporting
# ==============================

SCREENSHOT_ON_FAILURE=true
SCREENSHOT_EACH_STEP=true