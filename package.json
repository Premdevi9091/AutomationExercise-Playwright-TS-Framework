{
  "name": "automationexercise-playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf tests/test-reports tests/testLogs rerun.txt tests/test-reports/rerun-report.json",
    "report": "ts-node tests/support/reportManager.ts",
    "test:run": "cucumber-js -p default --tags \"@smoke\"",
    "test:all": "npm run clean && (npm run test:run || echo Tests failed) && npm run report",
    "test:rerun": "cucumber-js -p rerun @rerun.txt",
    "rerun": "npm run test:rerun && rimraf rerun.txt && npm run report || (echo Rerun still failing && npm run report)",
    "test": "npm run test:all",
    "addUser": "ts-node scripts/userManager.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@playwright/test": "^1.58.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.3.2",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^17.3.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "winston": "^3.19.0"
  }
}
